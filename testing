-- 🔓 [BagHelper] ขยายกระเป๋าถ้าเต็ม (พร้อม Fallback รับของก่อน)
-- ==========================================
local function EnsureBagHasSpace()
    local maxRetries = 3

    for attempt = 1, maxRetries do
        local current, max, reason = GetBagStatus()

        if reason ~= "OK" or not current or not max then
            warn(string.format("⚠️ [EnsureBag] ดึงสถานะกระเป๋าไม่ได้ (attempt %d) reason: %s", attempt, tostring(reason)))
            task.wait(1)
            continue
        end

        print(string.format("🎒 [EnsureBag] กระเป๋า: %d/%d (attempt %d)", current, max, attempt))

        -- ✅ กระเป๋าว่าง → ไม่ต้องทำอะไร
        if current < max then
            if _G.MoMoStatus then
                _G.MoMoStatus(string.format("กระเป๋าว่าง (%d/%d) พร้อมสุ่ม!", current, max))
            end
            return true
        end

        -- 🔴 กระเป๋าเต็ม → ลองขยายก่อน
        if _G.MoMoStatus then
            _G.MoMoStatus(string.format("กระเป๋าเต็ม (%d/%d)! กำลังขยาย...", current, max))
        end

        -- 💎 ก่อนอัปกระเป๋า เช็ค Gem ก่อน
        local gemReady = EnsureGemBeforeUpgradeBag()
        if not gemReady then
            warn("⚠️ [EnsureBag] Gem ยังน้อยกว่า 150 หลังรับ Task -> รอแล้วลองใหม่")
            if _G.MoMoStatus then
                _G.MoMoStatus("Gem ยังไม่พออัปกระเป๋า รอ 2s...")
            end
            task.wait(2)
        end

        print(string.format("🎒 [EnsureBag] กระเป๋าเต็ม! ส่ง UpgradeInventory (attempt %d)...", attempt))
        pcall(function()
            serverRemote:InvokeServer("UpgradeInventory")
        end)
        task.wait(1.5)

        -- เช็คว่า max เพิ่มขึ้นไหม
        local newCurrent, newMax, newReason = GetBagStatus()
        if newReason == "OK" and newMax and newMax > max then
            -- ✅ ขยายสำเร็จ
            print(string.format("✅ [EnsureBag] ขยายกระเป๋าสำเร็จ! %d/%d -> %d/%d", current, max, newCurrent, newMax))
            if _G.MoMoStatus then
                _G.MoMoStatus(string.format("ขยายกระเป๋าสำเร็จ! %d/%d พร้อมสุ่ม!", newCurrent, newMax))
            end
            return true
        end

        -- ❌ ขยายไม่ได้ (ไม่มีเงิน หรือ max ถูก cap) → กดรับของก่อน แล้วลองขยายอีกรอบ
        print(string.format("⚠️ [EnsureBag] ขยายไม่ได้ (max ไม่เพิ่ม: %s) -> กดรับของก่อน...", tostring(newMax)))
        if _G.MoMoStatus then
            _G.MoMoStatus("ขยายกระเป๋าไม่ได้! กำลังรับของค้างก่อน...")
        end

        ClaimAllStorageRewards()
        task.wait(1)

        -- ลองขยายอีกครั้งหลังรับของแล้ว
        print("[EnsureBag]ลองขยายกระเป๋าอีกรอบหลังรับของ...")
        EnsureGemBeforeUpgradeBag()
        pcall(function()
            serverRemote:InvokeServer("UpgradeInventory")
        end)
        task.wait(1.5)

        -- เช็ครอบสุดท้าย
        local finalCurrent, finalMax, finalReason = GetBagStatus()
        if finalReason == "OK" and finalMax and finalMax > max then
            print(string.format("✅ [EnsureBag] ขยายกระเป๋าสำเร็จหลังรับของ! %d/%d", finalCurrent, finalMax))
            if _G.MoMoStatus then
                _G.MoMoStatus(string.format("ขยายกระเป๋าสำเร็จ! (%d/%d)", finalCurrent, finalMax))
            end
            return true
        end

        -- ยังไม่ได้อีก → วนลูปลอง attempt ถัดไป
        warn(string.format("❌ [EnsureBag] ยังขยายไม่ได้หลังรับของ (attempt %d/%d)", attempt, maxRetries))
        task.wait(1)
    end

    -- ถ้าผ่าน maxRetries แล้วยังไม่ได้ → return false ให้ caller จัดการเอง
    warn("❌ [EnsureBag] ขยายกระเป๋าไม่สำเร็จหลังพยายาม " .. maxRetries .. " ครั้ง")
    return false
end

