                    local fastForward = hud:FindFirstChild("FastForward")
                    if fastForward then
                        local speedTextObj = (fastForward:FindFirstChild("SpeedText") and fastForward.SpeedText:FindFirstChild("TextLabel")) or fastForward:FindFirstChild("TextLabel")
                        if speedTextObj and speedTextObj:IsA("TextLabel") and speedTextObj.Text:upper() == "1X" then
                            inputRemote:FireServer("SpeedChange", true)
                        end
                    end
                end
                inputRemote:FireServer("VoteWaveConfirm")
            end)
        end
    end)

    -- 🧠 [SUB-MODULE]: ลอจิกการวางตัวละครตามแผน
    task.spawn(function()
        local PlacedUnits = {} -- ตารางเก็บหน่วยความจำว่าวางตัวไหนไปแล้วบ้าง
        local MacroStep = 1    -- ตัวนับว่าตอนนี้ทำถึงขั้นตอนไหนแล้ว

        -- 🛠️ ฟังก์ชันช่วยหาพิกัด
        local function getSlotCFrame(slotIndex)
            local fixedCF = nil
            pcall(function()
                local base = workspace:FindFirstChild("Placeable") and workspace.Placeable:FindFirstChild("Base")
                if base then
                    local slot = base:GetChildren()[slotIndex]
                    if slot then
                        local part = slot:FindFirstChild("Base_Part") or (slot:IsA("BasePart") and slot)
                        if part then fixedCF = part.CFrame end
                    end
                end
            end)
            return fixedCF
        end

        -- 🛠️ ฟังก์ชันช่วยหาชื่อการ์ดจากกระเป๋า (1-6)
        local function getCardNameBySlot(slotIndex)
            local hud = LocalPlayer.PlayerGui:FindFirstChild("HUD")
            if not hud then return nil, math.huge end
            local unitFrame = hud:FindFirstChild("BottomFrame") and hud.BottomFrame:FindFirstChild("Unit") or (hud:FindFirstChild("Main") and hud.Main:FindFirstChild("Unit"))
            if not unitFrame then return nil, math.huge end

            local slots = {"One", "Two", "Three", "Four", "Five", "Six"}
            local targetSlot = unitFrame:FindFirstChild(slots[slotIndex])
            
            if targetSlot and targetSlot:FindFirstChild("Unit") and targetSlot.Unit.Value ~= "" then
                local name = targetSlot.Unit.Value
                local cost = 9999
                for _, obj in ipairs(targetSlot:GetDescendants()) do
                    if (obj:IsA("TextLabel") or obj:IsA("TextButton")) and obj.Text:match("%d+") then
                        local c = tonumber(obj.Text:match("%d+"))
                        if c and c < cost then cost = c end
                    end
                end
                return name, cost
            end
            return nil, math.huge
        end

        -- 🛠️ ฟังก์ชันช่วยดึงเงิน
        local function getMoney()
            local m = LocalPlayer:FindFirstChild("Money")
            return m and tonumber(m.Value) or 0
        end

        -- 🛠️ ฟังก์ชันช่วยวางตัวละคร
        local function PlaceUnit(unitName, cf)
            if not unitName or not cf then return nil end
            local preCount = 0
            local unitFolder = workspace:FindFirstChild("Unit")
            if unitFolder then
                for _, u in ipairs(unitFolder:GetChildren()) do
                    if u.Name == unitName and u:FindFirstChild("Owner") and u.Owner.Value == LocalPlayer then preCount += 1 end
                end
            end

            pcall(function() inputRemote:FireServer("Summon", {Rotation = 0, cframe = cf, Unit = unitName}) end)
            task.wait(0.5) -- รอ Server เสกตัวละคร

            if unitFolder then
                local matches = {}
                for _, u in ipairs(unitFolder:GetChildren()) do
                    if u.Name == unitName and u:FindFirstChild("Owner") and u.Owner.Value == LocalPlayer then table.insert(matches, u) end
                end
                if #matches > preCount then return matches[#matches] end
            end
            return nil
        end

        -- 🛠️ ฟังก์ชันช่วยหาตัวละครจาก "ตำแหน่ง" (แม่นยำกว่าหาจากชื่อ)
        local function FindUnitByPosition(targetCF)
            if not targetCF then return nil end
            local unitFolder = workspace:FindFirstChild("Unit") or workspace
            for _, u in ipairs(unitFolder:GetChildren()) do
                if u:IsA("Model") then
                    local pos = nil
                    if u.PrimaryPart then pos = u.PrimaryPart.Position 
                    elseif u:FindFirstChild("HumanoidRootPart") then pos = u.HumanoidRootPart.Position
                    elseif u:FindFirstChild("Head") then pos = u.Head.Position end
                    
                    -- เช็คว่ามีโมเดลยืนอยู่ในระยะ 5 Studs จากจุดที่เราเล็งไว้หรือไม่
                    if pos and (pos - targetCF.Position).Magnitude < 5 then
                        return u
                    end
                end
            end
            return nil
        end

        -- 🛠️ ฟังก์ชันช่วยหาค่าอัปเกรด
        local function getUpgradeCost(unit)
            if not unit then return nil end
            local cost = nil
            pcall(function()
                cost = tonumber(unit:GetAttribute("UpgradeCost")) or tonumber(unit:GetAttribute("NextUpgradeCost")) or tonumber(unit:GetAttribute("Cost"))
            end)
            if not cost then
                for _, child in ipairs(unit:GetDescendants()) do
                    if child.Name:lower():find("upgradecost") or child.Name:lower():find("nextcost") then
                        local v = tonumber(child.Value)
                        if v and v > 0 then cost = v; break end
                    end
                end
            end
            return cost
        end

        -- 🚀 ลูปหลักของการทำตามคำสั่ง
        while task.wait(0.5) do
            if not _G.AutoPlayActive then continue end

            local myMoney = getMoney()

            -- [Step 1] วาง Unit ตัวแรกที่ Slot 24
            if MacroStep == 1 then
                local name, cost = getCardNameBySlot(1) -- ใช้ตัวละครสล็อตที่ 1 ของทีม
                if name and myMoney >= cost then
                    local cf = getSlotCFrame(24)
                    if cf then
                        if _G.MoMoStatus then _G.MoMoStatus("Step 1: วาง Unit 1 ที่ Slot 24") end
                        local unit = PlaceUnit(name, cf)
                        if unit then
                            PlacedUnits[1] = unit
                            MacroStep = 2
                            print("✅ Step 1: วาง Unit 1 สำเร็จ")
                        end
                    end
                end

            -- [Step 2] อัปเกรด Unit ตัวแรก 1 ขั้น (ค้นหาโมเดลจากพิกัด Slot 24)
            elseif MacroStep == 2 then
                local currentUnit1 = PlacedUnits[1]

                -- 🔄 ถ้าระบบจำตัวละครเก่าไม่ได้ (Parent=nil หรือโดนเปลี่ยนโมเดล) 
                -- ให้ใช้เรดาร์สแกนหาตัวละครที่ยืนอยู่ตรง Slot 24 แทน
                if not currentUnit1 or not currentUnit1.Parent then
                    currentUnit1 = FindUnitByPosition(getSlotCFrame(24))
                    if currentUnit1 then
                        PlacedUnits[1] = currentUnit1 -- อัปเดตความจำใหม่
                    end
                end

                if currentUnit1 and currentUnit1.Parent then
                    -- 🔍 ค้นหา UpgradeTag แบบทะลวงลึก
                    local tag = currentUnit1:FindFirstChild("UpgradeTag", true) or currentUnit1:FindFirstChild("UnitLevelTag", true)
                    local currentLevel = tag and tonumber(tag.Value) or 0
                    
                    if currentLevel >= 1 then
                        MacroStep = 3
                        print("✅ Step 2: อัปเกรด Unit 1 สำเร็จ (ตรวจพบ UpgradeTag = " .. currentLevel .. ")")
                    else
                        local upgCost = getUpgradeCost(currentUnit1) or 150
                        if myMoney >= upgCost then
                            if _G.MoMoStatus then _G.MoMoStatus("Step 2: ย้ำอัปเกรด Unit 1 (ตอนนี้ Level: " .. currentLevel .. ")") end
                            pcall(function() serverRemote:InvokeServer("Upgrade", currentUnit1) end)
                            task.wait(0.6)
                        else
                            if _G.MoMoStatus then _G.MoMoStatus("Step 2: รอเงินอัปเกรด Unit 1...") end
                        end
                    end
                else
                    if _G.MoMoStatus then _G.MoMoStatus("Step 2: ⚠️ หาตัวละครที่ Slot 24 ไม่เจอ!") end
                end

            -- [Step 3] วาง Unit ตัวที่ 2 ที่ Slot   
            elseif MacroStep == 3 then
                local name, cost = getCardNameBySlot(1) -- ใช้ตัวละครสล็อตที่ 2 ของทีม
                if name and myMoney >= cost then
                    local cf = getSlotCFrame(32)
                    if cf then
                        if _G.MoMoStatus then _G.MoMoStatus("Step 3: วาง Unit 2 ที่ Slot 32") end
                        local unit = PlaceUnit(name, cf)
                        if unit then
                            PlacedUnits[2] = unit
                            MacroStep = 4
                            print("✅ Step 3: วาง Unit 2 สำเร็จ")
                        end
                    end
                end

            -- [Step 4] วาง Unit ตัวที่ 3 ที่ Slot 32 (ขยับพิกัดเล็กน้อยกันทับกัน)
            elseif MacroStep == 4 then
                local name, cost = getCardNameBySlot(1) -- ใช้ตัวละครสล็อตที่ 3 ของทีม
                if name and myMoney >= cost then
                    local cf = getSlotCFrame(33)
                    if cf then
                        -- เพิ่ม Offset ขยับแกน X เล็กน้อย เพื่อให้ตัวที่ 3 วางข้างๆ ตัวที่ 2 ได
                        if _G.MoMoStatus then _G.MoMoStatus("Step 4: วาง Unit 3 ที่ Slot 32 (ข้างๆ)") end
                        local unit = PlaceUnit(name, cf)
                        if unit then
                            PlacedUnits[3] = unit
                            MacroStep = 5
                            print("✅ Step 4: วาง Unit 3 สำเร็จ")
                        end
                    end
                end

            -- [Step 5] วาง Unit ตัวที่ 4 ที่ Slot 31 workspace.Placeable.Base:GetChildren()[27].Base_Part
            elseif MacroStep == 5 then
                local name, cost = getCardNameBySlot(1) 
                if name and myMoney >= cost then
                    local cf = getSlotCFrame(27)
                    if cf then
                        if _G.MoMoStatus then _G.MoMoStatus("Step 5: วาง Unit 4 ที่ Slot 31") end
                        local unit = PlaceUnit(name, cf)
                        if unit then
                            PlacedUnits[4] = unit
                            MacroStep = 6
                            print("✅ Step 5: วาง Unit 4 สำเร็จ")
                        end
                    end
                end

            -- [Step 6] โหมดท้ายเกม: เมื่อเงิน > 1000 ให้อัปเกรดเฉพาะตัว 2, 3, 4 รัวๆ
            elseif MacroStep == 6 then
                if myMoney > 1000 then
                    if _G.MoMoStatus then _G.MoMoStatus("Step 6: สแปมอัปเกรด 2, 3, 4 (เงิน > 1000)") end
                    
                    for i = 2, 4 do
                        local targetUnit = PlacedUnits[i]
                        
                        -- เช็คแค่ว่าตัวละครยังยืนอยู่บนแมพไหม ถ้าอยู่ ยิง Remote เลย!
                        if targetUnit and targetUnit.Parent then
                            pcall(function() 
                                serverRemote:InvokeServer("Upgrade", targetUnit) 
                            end)
                            
                            -- หน่วงเวลาเล็กน้อยเพื่อป้องกันเซิร์ฟเวอร์เกมเตะออกหาว่าใช้โปรแกรมสแปม
                            task.wait(0.3) 
                        end
                    end
                else
                    if _G.MoMoStatus then _G.MoMoStatus("กำลังรอเงิน > 1000 เพื่ออัปเกรด...") end
                end
            end
        end
    end)

    -- ⏭️ [SUB-MODULE]: Auto Play Next / Replay (ใช้โค้ดเดิมที่จัดการหน้าสรุปผลตอนจบด่าน)
    task.spawn(function()
        local VIM = game:GetService("VirtualInputManager")
        local playerGui = LocalPlayer:WaitForChild("PlayerGui")
        local guiService = game:GetService("GuiService")
        
        local function findButtonByKeyword(keywords)
            for _, gui in pairs(playerGui:GetDescendants()) do
                if (gui:IsA("TextButton") or gui:IsA("ImageButton")) and gui.Visible and gui.AbsolutePosition.X > 0 then
                    local text = gui:IsA("TextButton") and gui.Text or ""
                    for _, child in pairs(gui:GetChildren()) do
                        if child:IsA("TextLabel") then text = text .. " " .. child.Text end
                    end
                    text = text:lower()
                    local name = gui.Name:lower()
                    for _, kw in ipairs(keywords) do
                        if text:find(kw) or name:find(kw) then
                            local isReallyVisible = true
                            local curr = gui
                            while curr and curr ~= playerGui do
                                if curr:IsA("GuiObject") and not curr.Visible then isReallyVisible = false break end
                                curr = curr.Parent
                            end
                            if isReallyVisible then return gui end
                        end
                    end
                end
            end
            return nil
        end
        
        while task.wait(2) do
            if not _G.AutoPlayActive then continue end
            pcall(function()
                local currentStage = GetCurrentStoryLevel()
                local targetButton = nil
                local actionName = ""
                
                if currentStage and currentStage <= 0 then
                    targetButton = findButtonByKeyword({"replay", "next stage", "next"})
                    actionName = "Replay"
                else
                    targetButton = findButtonByKeyword({"replay", "play again", "again", "retry", "play next"})
                    actionName = "Replay"
                end
                
                if targetButton then
                    local aP, aS = targetButton.AbsolutePosition, targetButton.AbsoluteSize
                    local inset = guiService:GetGuiInset()
                    local targetX = aP.X + (aS.X / 2)
                    local targetY = aP.Y + (aS.Y / 2) + inset.Y
                    for i = 1, 2 do
                        VIM:SendMouseButtonEvent(targetX, targetY, 0, true, game, 1)
                        task.wait(0.1)
                        VIM:SendMouseButtonEvent(targetX, targetY, 0, false, game, 1)
                        task.wait(0.2)
                    end
                    task.wait(8)
                end
            end)
        end
    end)
end


