function Tutorial.AutoSummonUntilFound()
    if HasTargetUnitInInventory() then
        print("✅ [AutoSummon] มียูนิตเป้าหมายอยู่แล้ว ไม่ต้อง summon")
        return true
    end

    local summonAttempts = 0
    local maxAttempts = 50

    while summonAttempts < maxAttempts do

        -- 🎁 เช็ค Stardust ก่อนสุ่ม
        local stardustReady = EnsureStardustBeforeSummon()
        if not stardustReady then
            warn("⚠️ [AutoSummon] Stardust ยังน้อยกว่า 50 หลังรับ GiftBox -> รอ 3s แล้วลองใหม่")
            if _G.MoMoStatus then
                _G.MoMoStatus("Stardust ยังไม่พอสุ่ม รอ 3s...")
            end
            task.wait(3)
            continue
        end

        -- 🔑 ตรวจกระเป๋าก่อนสุ่มทุกครั้ง
        local bagReady = EnsureBagHasSpace()
        if not bagReady then
            warn("⚠️ [AutoSummon] กระเป๋ายังเต็ม/ขยายไม่ได้ -> รอ 5s แล้วลองใหม่")
            if _G.MoMoStatus then
                _G.MoMoStatus("กระเป๋าเต็ม/ขยายไม่ได้ รอ 5s...")
            end
            task.wait(5)
            continue
        end

        -- ✅ กระเป๋าว่างแล้ว → สุ่มได้
        summonAttempts += 1
        if _G.MoMoStatus then
            _G.MoMoStatus(string.format("กระเป๋าว่าง -> กำลังสุ่ม Banner... (ครั้งที่ %d)", summonAttempts))
        end

        local ok, err = pcall(function()
            local args = {
                "BannerSummon",
                10,
                "Rerun101"
            }
            serverRemote:InvokeServer(unpack(args))
        end)

        if ok then
            print("🎰 [AutoSummon] สุ่มครั้งที่", summonAttempts, "สำเร็จ")
        else
            warn("❌ [AutoSummon] summon ล้มเหลว:", tostring(err))
        end

        -- ⏸️ รอให้ Giftbox claim เสร็จก่อนค่อยสุ่มครั้งถัดไป
        local giftWait = 0
        while _G.GiftboxClaiming and giftWait < 30 do
            task.wait(0.5)
            giftWait += 0.5
        end
        if giftWait > 0 then
            print("⏸️ [AutoSummon] รอ Giftbox เสร็จ " .. giftWait .. "s แล้วสุ่มต่อ")
        end

        task.wait(2.5)

        if HasTargetUnitInInventory() then
            print("🏁 [AutoSummon] พบยูนิตเป้าหมายหลังจาก summon ครั้งที่", summonAttempts)
            _G.TutorialSummonDone = true
            return true
        end

        task.wait(0.75)
    end

    warn("⚠️ [AutoSummon] เกินจำนวนครั้งที่กำหนด แต่ยังไม่พบยูนิตเป้าหมาย")
    return false
end

