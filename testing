    local function NormalizeName(text)
        return tostring(text or ""):lower():gsub("%s+", "")
    end

    local function HasTargetUnitInInventory()
        local targetNames = {
            " ",
            " ",
        }

        Tutorial.ForceLoadInventoryUI()
        task.wait(1.5)

        local invV2 = hud:FindFirstChild("InventoryV2")
        local scroll = invV2 and invV2:FindFirstChildWhichIsA("ScrollingFrame", true)
        if not scroll then
            warn("❌ [HasTargetUnitInInventory] หา Inventory Scroll ไม่เจอ")
            return false
        end

        for _, uiObj in pairs(scroll:GetChildren()) do
            if uiObj:IsA("GuiObject") then
                local unitName = uiObj.Name
                local nameLabel = uiObj:FindFirstChild("UnitName", true) or uiObj:FindFirstChild("MainName", true)
                if nameLabel and nameLabel:IsA("TextLabel") and nameLabel.Text ~= "" then
                    unitName = nameLabel.Text
                end

                local normalizedUnit = NormalizeName(unitName)
                for _, target in ipairs(targetNames) do
                    local normalizedTarget = NormalizeName(target)
                    if normalizedUnit == normalizedTarget or normalizedUnit:find(normalizedTarget) then
                        print("✅ [SummonCheck] พบยูนิตเป้าหมายแล้ว:", unitName)
                        return true
                    end
                end
            end
        end

        return false
    end

