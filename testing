                for _, v in pairs(bF:GetDescendants()) do
                    if v:IsA("StringValue") and v.Value ~= "" and v.Value ~= "Empty" then
                        table.insert(currentTeam, tostring(v.Value))
                    elseif v:IsA("Model") and v.Parent and v.Parent.Name == "WorldModel" then
                        table.insert(currentTeam, v.Name)
                    end
                end
            end
        end

        -- ค้นหายูนิตที่ตรงกับแต่ละสล็อตจาก Inventory
        local equipList = {}  -- { slot = 1, unit = {Name, ID, Level} }

        print("========== DEBUG INVENTORY ==========")
        print("Scroll ชื่อ:", scroll.Name, "จำนวนลูก:", #scroll:GetChildren())
        for _, uiObj in pairs(scroll:GetChildren()) do
            if uiObj:IsA("GuiObject") then
                local nameLabel = uiObj:FindFirstChild("UnitName", true) or uiObj:FindFirstChild("MainName", true)
                local displayName = nameLabel and nameLabel.Text or uiObj.Name
                print("  -", displayName, "(uiObj.Name=" .. uiObj.Name .. ")")
            end
        end
        print("=====================================")

        for _, target in ipairs(slotTargets) do
            local foundUnit = nil
            local foundID = nil
            local foundLevel = 1

            for _, uiObj in pairs(scroll:GetChildren()) do
                if uiObj:IsA("GuiObject") then
                    local unitName = uiObj.Name
                    local nameLabel = uiObj:FindFirstChild("UnitName", true) or uiObj:FindFirstChild("MainName", true)
                    if nameLabel and nameLabel:IsA("TextLabel") and nameLabel.Text ~= "" then
                        unitName = nameLabel.Text
                    end

                    -- ตรวจสอบชื่อตรงกับ names ใน target หรือไม่ (แบบยืดหยุ่น)
                    local match = false
                    local normalizedUnit = unitName:lower():gsub("%s+", "")  -- ลบช่องว่าง, พิมพ์เล็ก
                    for _, n in ipairs(target.names) do
                        local normalizedTarget = n:lower():gsub("%s+", "")
                        if normalizedUnit == normalizedTarget or normalizedUnit:find(normalizedTarget) then
                            match = true
                            break
                        end
                    end
                    if not match then continue end

                    -- ดึง ID และ Level
                    local unitID = nil
                    local unitLevel = 1
                    pcall(function()
                        unitID = uiObj:GetAttribute("uid") or uiObj:GetAttribute("uuid") or uiObj:GetAttribute("ID")
                        unitLevel = tonumber(uiObj:GetAttribute("level") or uiObj:GetAttribute("Level")) or 1
                    end)

                    -- Fallback 1: หา child ที่ชื่อมี id/uid/uuid
                    if not unitID then
                        for _, child in pairs(uiObj:GetDescendants()) do
                            if child:IsA("StringValue") or child:IsA("IntValue") or child:IsA("NumberValue") then
                                local cn = child.Name:lower()
                                if cn:find("id") or cn:find("uid") or cn == "uuid" then
                                    unitID = child.Value
                                    break
                                end
                            end
                        end
                    end

                    -- Fallback 2: ใช้ memory scan (getgc)
                    if not unitID then
                        pcall(function()
                            for _, v in pairs(getgc(true)) do
                                if type(v) == "table" then
                                    local id = rawget(v, "uid") or rawget(v, "uuid") or rawget(v, "ID")
                                    local name = rawget(v, "unitId") or rawget(v, "Name") or rawget(v, "UnitName")
                                    if id and name then
                                        local nameStr = tostring(name)
                                        if nameStr == unitName or nameStr:lower() == unitName:lower() then
                                            unitID = id
                                            unitLevel = rawget(v, "level") or rawget(v, "Level") or 1
                                            break
                                        end
                                    end
                                end
                            end
                        end)
                    end
                    if unitID then
                        foundUnit = unitName
                        foundID = unitID
                        foundLevel = unitLevel
                        break
                    end
                end
            end

            if foundUnit and foundID then
                table.insert(equipList, {
                    slot = target.slot,
                    name = foundUnit,
                    id = foundID,
                    level = foundLevel
                })
                print(string.format("✅ พบ %s สำหรับสล็อต %d", foundUnit, target.slot))
            else
                warn(string.format("⚠️ ไม่พบยูนิตสำหรับสล็อต %d (ชื่อ: %s)", target.slot, table.concat(target.names, ", ")))
            end
        end

        -- ถอดทีมเก่าทั้งหมด
        for _, currentID in ipairs(currentTeam) do
            pcall(function() inputRemote:FireServer("Unequip", {Stats = currentID}) end)
            task.wait(0.3)
        end
        task.wait(1)

        -- ใส่ทีมใหม่ตาม equipList
        -- เรียง equipList ตาม slot
        table.sort(equipList, function(a,b) return a.slot < b.slot end)

        for _, item in ipairs(equipList) do
            local idStr
            if type(item.id) == "string" and not tonumber(item.id) then
                idStr = '"' .. tostring(item.id) .. '"'
            else
                idStr = tostring(item.id)
            end
            local safeName = tostring(item.name):gsub('"', '\\"')
            local statsJson = string.format('{"ID":%s,"Level":%d,"Name":"%s"}', idStr, item.level, safeName)

            local success, err = pcall(function()
                serverRemote:InvokeServer("Equip", {Stats = statsJson})
            end)
            if success then
                print(string.format("✅ ใส่ %s ในสล็อต %d สำเร็จ", item.name, item.slot))
            else
                warn(string.format("❌ ใส่ %s ในสล็อต %d ล้มเหลว: %s", item.name, item.slot, tostring(err)))
            end
            task.wait(0.6)
        end

        task.wait(1.5)

        -- validate หลังใส่
        local equippedNow = {}
        do
            local bF = hud:FindFirstChild("BottomFrame") or hud:FindFirstChild("Main")
            if bF then
                for _, v in pairs(bF:GetDescendants()) do
                    if v:IsA("StringValue") and v.Value ~= "" and v.Value ~= "Empty" then
                        table.insert(equippedNow, tostring(v.Value))
                    elseif v:IsA("Model") and v.Parent and v.Parent.Name == "WorldModel" then
                        table.insert(equippedNow, v.Name)
                    end
                end
            end
        end

        if #equippedNow >= #equipList then
            print("🏁 [SmartEquip] ใส่ทีมสำเร็จ")
            return true
        end

        warn("❌ [SmartEquip] ถอดตัวแล้ว แต่ใส่กลับไม่ครบ")
        return false
    end

